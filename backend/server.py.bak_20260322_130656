@app.route("/stream-chat", methods=["POST"])
def stream_chat():
    user, err = require_user()
    if err:
        return err

    data = request.get_json(silent=True) or {}
    message = (data.get("message") or "").strip()
    thread_id = int(data.get("thread_id") or ensure_default_thread(user["id"]))
    preset_key = (data.get("preset_key") or "").strip()

    if not message:
        return jsonify({"error": "Message is required"}), 400

    thread = get_thread_owned(user["id"], thread_id)
    if not thread:
        return jsonify({"error": "Thread not found"}), 404

    final_prompt = message
    if preset_key:
        conn = db()
        preset = conn.execute(
            "SELECT * FROM presets WHERE preset_key = ? AND (is_system = 1 OR user_id = ?)",
            (preset_key, user["id"])
        ).fetchone()
        conn.close()
        if preset:
            final_prompt = (preset["prompt_template"] or "").replace("{{input}}", message)

    response_text = maybe_generate_text(final_prompt)

    def generate():
        words = response_text.split()
        if not words:
            yield ""
        else:
            for i, word in enumerate(words):
                yield (word + (" " if i < len(words) - 1 else ""))
                time.sleep(0.015)

    add_message(thread_id, user["id"], "user", message, None)
    add_message(thread_id, user["id"], "assistant", response_text, "SemantiqAI Stream")
    add_history(user["id"], "SemantiqAI Stream", message, response_text)

    return Response(generate(), mimetype="text/plain")

@app.route("/upload/csv", methods=["POST"])
def upload_csv():
    user, err = require_user()
    if err:
        return err

    if "file" not in request.files:
        return jsonify({"error": "No file uploaded"}), 400

    f = request.files["file"]
    if not f or not f.filename:
        return jsonify({"error": "Invalid file"}), 400

    filename = f.filename
    ext = os.path.splitext(filename)[1].lower()
    if ext != ".csv":
        return jsonify({"error": "Only CSV uploads are supported in this route"}), 400

    safe_name = uuid.uuid4().hex + "_" + os.path.basename(filename)
    saved_path = UPLOADS_DIR / safe_name
    f.save(saved_path)

    try:
        text = saved_path.read_text(encoding="utf-8", errors="ignore")
        reader = csv.DictReader(io.StringIO(text))
        rows = list(reader)
        columns = reader.fieldnames or []

        numeric_summary = {}
        for col in columns:
            values = []
            for row in rows[:1000]:
                raw = (row.get(col) or "").strip()
                if raw == "":
                    continue
                try:
                    values.append(float(raw))
                except Exception:
                    pass
            if values:
                numeric_summary[col] = {
                    "count": len(values),
                    "min": min(values),
                    "max": max(values),
                    "avg": sum(values) / len(values)
                }

        sample_rows = rows[:10]

        return jsonify({
            "ok": True,
            "filename": filename,
            "saved_as": safe_name,
            "rows": len(rows),
            "columns": columns,
            "sample_rows": sample_rows,
            "numeric_summary": numeric_summary
        })
    except Exception as e:
        return jsonify({"error": f"CSV analysis failed: {e}"}), 500

