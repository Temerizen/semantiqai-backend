@app.post("/agent-council/run")
def agent_council_run():
    user, err = require_user()
    if err:
        return err

    data = request.get_json(silent=True) or {}
    message = (data.get("message") or "").strip()
    thread_id = int(data.get("thread_id") or ensure_default_thread(user["id"]))
    explicit_agents = data.get("agents") or []

    if not message:
        return jsonify({"error": "Message is required"}), 400

    thread = get_thread_owned(user["id"], thread_id)
    if not thread:
        return jsonify({"error": "Thread not found"}), 404

    chosen_agents = explicit_agents if explicit_agents else route_agents(message)
    runs = []
    outputs = []

    add_message(thread_id, user["id"], "user", message, None)

    for agent_key in chosen_agents:
        result = run_agent(agent_key, message)
        save_agent_run(user["id"], thread_id, result["agent_key"], result["agent_title"], message, result["output"])
        add_message(thread_id, user["id"], "assistant", result["output"], result["agent_title"])
        runs.append({
            "agent_key": result["agent_key"],
            "agent_title": result["agent_title"],
            "output": result["output"]
        })
        outputs.append(f"[{result['agent_title']}]\n{result['output']}")

    synthesis_prompt = (
        "You are the SemantiqAI Agent Council Synthesizer. Combine the following agent outputs into one structured, practical final answer with sections for strategy, execution, risks, and next moves.\n\n"
        + "\n\n".join(outputs)
    )
    final = maybe_generate_text(synthesis_prompt)
    add_message(thread_id, user["id"], "assistant", final, "Agent Council Synthesis")
    add_history(user["id"], "Agent Council", message, final)

    return jsonify({
        "thread_id": thread_id,
        "agents_used": runs,
        "final": final
    })

