def create_artifact(user_id, thread_id, title, artifact_type, content):
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    safe_title = "".join(c if c.isalnum() or c in ("-", "_") else "_" for c in (title or "artifact"))[:60]
    filename = f"{safe_title}_{stamp}.txt"
    path = EXPORTS_DIR / filename
    path.write_text(content, encoding="utf-8")

    conn = db()
    conn.execute(
        "INSERT INTO artifacts (user_id, thread_id, title, artifact_type, filename, file_path, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)",
        (user_id, thread_id, title, artifact_type, filename, str(path), utc_now())
    )
    conn.commit()
    conn.close()

    return {
        "title": title,
        "artifact_type": artifact_type,
        "filename": filename,
        "file_path": str(path)
    }

