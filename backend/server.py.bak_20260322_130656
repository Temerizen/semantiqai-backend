@app.route("/memory/search", methods=["POST"])
def search_memory():
    user, err = require_user()
    if err:
        return err

    data = request.get_json(silent=True) or {}
    query = (data.get("query") or "").strip().lower()

    conn = db()
    rows = conn.execute(
        "SELECT id, thread_id, memory_type, title, content, tags, score, created_at FROM memory_items WHERE user_id = ? ORDER BY score DESC, id DESC LIMIT 300",
        (user["id"],)
    ).fetchall()
    conn.close()

    if not query:
        matches = [dict(r) for r in rows[:20]]
        return jsonify({"items": matches})

    scored = []
    for r in rows:
        item = dict(r)
        hay = " ".join([
            str(item.get("title") or ""),
            str(item.get("content") or ""),
            str(item.get("tags") or "")
        ]).lower()
        score = 0
        for token in query.split():
            if token in hay:
                score += 1
        if score > 0:
            item["_match_score"] = score + float(item.get("score") or 1.0)
            scored.append(item)

    scored.sort(key=lambda x: x["_match_score"], reverse=True)
    return jsonify({"items": scored[:30]})

