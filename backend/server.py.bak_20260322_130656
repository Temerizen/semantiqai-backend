def token_for_user(user):
    return serializer.dumps({
        "id": user["id"],
        "username": user["username"],
        "role": user["role"]
    })

def user_from_token():
    auth = request.headers.get("Authorization", "")
    if not auth.startswith("Bearer "):
        return None
    token = auth.split(" ", 1)[1].strip()
    if not token:
        return None
    try:
        payload = serializer.loads(token)
    except BadSignature:
        return None
    conn = db()
    row = conn.execute(
        "SELECT id, username, role, created_at FROM users WHERE id = ?",
        (payload.get("id"),)
    ).fetchone()
    conn.close()
    return row

def require_user():
    user = user_from_token()
    if not user:
        return None, (jsonify({"error": "Authentication required"}), 401)
    return user, None

def require_founder():
    user, err = require_user()
    if err:
        return None, err
    if user["role"] not in ("founder", "admin"):
        return None, (jsonify({"error": "Founder access required"}), 403)
    return user, None

def client_key():
    auth = request.headers.get("Authorization", "")
    if auth.startswith("Bearer "):
        return f"token:{auth[:48]}"
    forwarded = request.headers.get("X-Forwarded-For", "").split(",")[0].strip()
    ip = forwarded or request.remote_addr or "unknown"
    return f"ip:{ip}"

@app.before_request
def apply_rate_limit():
    exempt = {"/", "/status", "/health", "/ready"}
    if request.path in exempt or request.path.startswith("/manifest") or request.path.startswith("/robots") or request.path.startswith("/sitemap"):
        return None

    key = client_key()
    now = datetime.now(timezone.utc)
    bucket = rate_buckets[key]
    cutoff = now - timedelta(minutes=1)

    while bucket and bucket[0] < cutoff:
        bucket.popleft()

    if len(bucket) >= RATE_LIMIT_PER_MINUTE:
        return jsonify({"error": "Rate limit exceeded", "limit_per_minute": RATE_LIMIT_PER_MINUTE}), 429

    bucket.append(now)
    return None

def log_request_row(status_code):
    try:
        user = user_from_token()
        uid = user["id"] if user else None
        conn = db()
        conn.execute(
            "INSERT INTO request_logs (user_id, route, method, status_code, created_at) VALUES (?, ?, ?, ?, ?)",
            (uid, request.path, request.method, int(status_code), utc_now())
        )
        conn.commit()
        conn.close()
    except Exception:
        pass

@app.after_request
def after_request(response):
    response.headers["X-App-Name"] = APP_NAME
    response.headers["X-App-Version"] = APP_VERSION
    response.headers["X-App-Stage"] = APP_STAGE
    response.headers["Cache-Control"] = "no-store"
    response.headers["X-Content-Type-Options"] = "nosniff"
    response.headers["X-Frame-Options"] = "SAMEORIGIN"
    response.headers["Referrer-Policy"] = "strict-origin-when-cross-origin"
    response.headers["Permissions-Policy"] = "camera=(), microphone=(), geolocation=()"
    if request.is_secure or (PUBLIC_BASE_URL.startswith("https://") if PUBLIC_BASE_URL else False):
        response.headers["Strict-Transport-Security"] = "max-age=31536000; includeSubDomains"
    log_request_row(response.status_code)
    return response

@app.errorhandler(Exception)
def handle_exception(e):
    trace_id = datetime.now().strftime("%Y%m%d%H%M%S%f")
    print(f"[ERROR {trace_id}] {e}")
    traceback.print_exc()
    return jsonify({"error": "Internal server error", "trace_id": trace_id}), 500

def maybe_generate_text(prompt: str) -> str:
    prompt = (prompt or "").strip()
    if not prompt:
        return "No prompt provided."

    try:
        from backend.ai_engine import generate_text
        result = generate_text(prompt)
        if result:
            return str(result).strip()
    except Exception:
        pass

    try:
        from openai import OpenAI
        if OPENAI_API_KEY:
            client = OpenAI(api_key=OPENAI_API_KEY)
            response = client.responses.create(model=OPENAI_MODEL, input=prompt)
            text = getattr(response, "output_text", None)
            if text:
                return text.strip()
    except Exception:
        pass

    return (
        "SemantiqAI fallback response:\n\n"
        f"{prompt}\n\n"
        "The AI engine is not fully wired yet, so this is the local fallback layer."
    )

def ensure_default_thread(user_id):
    conn = db()
    row = conn.execute(
        "SELECT id, title, is_archived, created_at, updated_at FROM threads WHERE user_id = ? ORDER BY updated_at DESC, id DESC LIMIT 1",
        (user_id,)
    ).fetchone()
    if row:
        conn.close()
        return row["id"]
    now = utc_now()
    conn.execute(
        "INSERT INTO threads (user_id, title, is_archived, created_at, updated_at) VALUES (?, ?, 0, ?, ?)",
        (user_id, "Main Thread", now, now)
    )
    conn.commit()
    thread_id = conn.execute("SELECT last_insert_rowid() AS id").fetchone()["id"]
    conn.close()
    return thread_id

