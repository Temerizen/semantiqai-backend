            (preset_key, user["id"])
        ).fetchone()
        conn.close()
        if preset:
            final_prompt = (preset["prompt_template"] or "").replace("{{input}}", message)

    conn = db()
    enriched_prompt, context_meta = compose_intelligence_prompt(conn, user["id"], final_prompt, thread_id)
    response_text = maybe_generate_text(enriched_prompt)

    add_message(thread_id, user["id"], "user", message, None)
    add_message(thread_id, user["id"], "assistant", response_text, "SemantiqAI Stream")
    add_history(user["id"], "SemantiqAI Stream", message, response_text)

    captured = store_memory_candidates(conn, user["id"], thread_id, message, response_text)
    create_growth_event(conn, "stream_chat", "authenticated_app", {
        "thread_id": thread_id,
        "preset_key": preset_key,
        "memory_count": context_meta.get("memory_count", 0),
        "profile_used": context_meta.get("profile_used", False),
        "captured_memories": captured
    }, user["id"])
    conn.commit()
    conn.close()

    def generate():
        yield "event: meta\ndata: " + json.dumps({
            "thread_id": thread_id,
            "memory_context_used": context_meta.get("memory_count", 0),
            "profile_context_used": context_meta.get("profile_used", False),
            "captured_memories": captured
        }) + "\n\n"

        for chunk in stream_chunks(response_text, max_words=8):
            yield "event: token\ndata: " + json.dumps({"token": chunk}) + "\n\n"
            time.sleep(0.02)

        yield "event: done\ndata: " + json.dumps({"ok": True}) + "\n\n"

    return Response(
        generate(),
        mimetype="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "X-Accel-Buffering": "no"
        }
    )

@app.route("/upload/csv", methods=["POST"])
def upload_csv():
    user, err = require_user()
    if err:
        return err

    if "file" not in request.files:
        return jsonify({"error": "No file uploaded"}), 400

    f = request.files["file"]
    if not f or not f.filename:
        return jsonify({"error": "Invalid file"}), 400

    filename = f.filename
    ext = os.path.splitext(filename)[1].lower()
    if ext != ".csv":
        return jsonify({"error": "Only CSV uploads are supported in this route"}), 400

    safe_name = uuid.uuid4().hex + "_" + os.path.basename(filename)
    saved_path = UPLOADS_DIR / safe_name
    f.save(saved_path)

    try:
        text = saved_path.read_text(encoding="utf-8", errors="ignore")
        reader = csv.DictReader(io.StringIO(text))
        rows = list(reader)
        columns = reader.fieldnames or []

        numeric_summary = {}
        for col in columns:
            values = []
            for row in rows[:1000]:
                raw = (row.get(col) or "").strip()
                if raw == "":
                    continue
                try:
                    values.append(float(raw))
                except Exception:
                    pass
            if values:
                numeric_summary[col] = {
                    "count": len(values),
                    "min": min(values),
                    "max": max(values),
                    "avg": sum(values) / len(values)
                }

        sample_rows = rows[:10]

        return jsonify({
            "ok": True,
            "filename": filename,
            "saved_as": safe_name,
            "rows": len(rows),
            "columns": columns,
            "sample_rows": sample_rows,
            "numeric_summary": numeric_summary
        })
    except Exception as e:
        return jsonify({"error": f"CSV analysis failed: {e}"}), 500

