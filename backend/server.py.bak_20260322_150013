def _education_make_course(topic, level="adaptive", audience="general"):
    prompt = f"""
You are building a world-class course.

Topic: {topic}
Level: {level}
Audience: {audience}

Return valid JSON only with this shape:
{{
  "title": "...",
  "subject": "{topic}",
  "description": "...",
  "objectives": ["...", "..."],
  "lessons": [
    {{
      "title": "...",
      "lesson_type": "core",
      "difficulty": "{level}",
      "estimated_minutes": 20,
      "content": "...",
      "exercises": ["...", "..."],
      "key_terms": ["...", "..."]
    }}
  ]
}}

Requirements:
- 8 lessons
- clear progression
- suitable for serious learners
- rigorous but accessible
- no markdown fences
"""
    raw = generate_text(prompt, temperature=0.4, max_tokens=2600)
    try:
        data = json.loads(raw)
    except Exception:
        data = {
            "title": f"{topic} Mastery Track",
            "subject": topic,
            "description": f"Adaptive course for {topic}.",
            "objectives": [
                f"Build a strong foundation in {topic}",
                f"Practice high-value concepts in {topic}",
                f"Apply {topic} with increasing rigor"
            ],
            "lessons": [
                {
                    "title": f"{topic} Foundations",
                    "lesson_type": "core",
                    "difficulty": level,
                    "estimated_minutes": 25,
                    "content": raw[:5000] if raw else f"Structured introduction to {topic}.",
                    "exercises": [
                        f"Summarize the central ideas of {topic}",
                        f"Explain one concept from {topic} in your own words"
                    ],
                    "key_terms": [topic, "fundamentals", "practice"]
                }
            ]
        }
    return data

