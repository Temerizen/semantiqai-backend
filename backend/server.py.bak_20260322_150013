                (lesson.get("lesson_type") or "core")[:50],
                (lesson.get("difficulty") or level)[:80],
                int(lesson.get("estimated_minutes") or 20),
                (lesson.get("content") or "")[:12000],
                json.dumps((lesson.get("exercises") or [])[:20]),
                json.dumps((lesson.get("key_terms") or [])[:20]),
                now,
                now
            )
        )

    conn.commit()
    row = conn.execute(
        "SELECT id, title, subject, level, audience, description, objectives_json, syllabus_json, created_at, updated_at FROM education_courses WHERE id = ?",
        (course_id,)
    ).fetchone()
