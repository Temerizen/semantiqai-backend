@app.post("/onboarding/complete")
def onboarding_complete():
    user, err = require_user()
    if err:
        return err

    data = request.get_json(silent=True) or {}
    goal = (data.get("goal") or "").strip()
    mode = (data.get("mode") or "").strip()
    preferences = data.get("preferences") or []

    now = utc_now()
    conn = db()

    conn.execute(
        "INSERT INTO onboarding_state (user_id, completed, selected_goal, selected_mode, created_at, updated_at) "
        "VALUES (?, ?, ?, ?, ?, ?) "
        "ON CONFLICT(user_id) DO UPDATE SET completed = excluded.completed, selected_goal = excluded.selected_goal, "
        "selected_mode = excluded.selected_mode, updated_at = excluded.updated_at",
        (user["id"], 1, goal[:120], mode[:120], now, now)
    )

    if _table_exists_public("user_profiles"):
        existing = conn.execute("SELECT goals, preferences, traits FROM user_profiles WHERE user_id = ?", (user["id"],)).fetchone()
        if existing:
            try:
                goals = json.loads(existing["goals"] or "[]")
                prefs = json.loads(existing["preferences"] or "[]")
                traits = json.loads(existing["traits"] or "[]")
            except Exception:
                goals, prefs, traits = [], [], []
        else:
            goals, prefs, traits = [], [], []

        if goal and goal not in goals:
            goals.insert(0, goal)
        for p in preferences:
            p = str(p).strip()
            if p and p not in prefs:
                prefs.append(p)

        conn.execute(
            "INSERT INTO user_profiles (user_id, goals, preferences, traits, updated_at) VALUES (?, ?, ?, ?, ?) "
            "ON CONFLICT(user_id) DO UPDATE SET goals = excluded.goals, preferences = excluded.preferences, traits = excluded.traits, updated_at = excluded.updated_at",
            (user["id"], json.dumps(goals[:12]), json.dumps(prefs[:20]), json.dumps(traits[:20]), now)
        )

    if _table_exists_public("growth_events"):
        conn.execute(
            "INSERT INTO growth_events (user_id, event_type, source, payload_json, created_at) VALUES (?, ?, ?, ?, ?)",
            (user["id"], "onboarding_completed", "app_onboarding", json.dumps({"goal": goal, "mode": mode}), now)
        )

    conn.commit()
    conn.close()
    return jsonify({"ok": True, "goal": goal, "mode": mode})

