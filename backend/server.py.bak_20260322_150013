def _update_cognitive_streak(user_id):
    if not _table_exists_ccl("cognitive_streaks"):
        return
    today = _today_iso()
    conn = db()
    row = conn.execute("SELECT * FROM cognitive_streaks WHERE user_id = ?", (user_id,)).fetchone()
    now = utc_now()
    if not row:
        conn.execute(
            "INSERT INTO cognitive_streaks (user_id, current_streak, best_streak, last_activity_date, updated_at) VALUES (?, 1, 1, ?, ?)",
            (user_id, today, now)
        )
        conn.commit()
        conn.close()
        return

    current_streak = int(row["current_streak"] or 0)
    best_streak = int(row["best_streak"] or 0)
    last_date = row["last_activity_date"] or ""

    try:
        d1 = datetime.strptime(last_date, "%Y-%m-%d").date() if last_date else None
        d2 = datetime.strptime(today, "%Y-%m-%d").date()
    except Exception:
        d1 = None
        d2 = None

    if last_date == today:
        conn.execute("UPDATE cognitive_streaks SET updated_at = ? WHERE user_id = ?", (now, user_id))
    elif d1 and d2 and (d2 - d1).days == 1:
        current_streak += 1
        best_streak = max(best_streak, current_streak)
        conn.execute(
            "UPDATE cognitive_streaks SET current_streak = ?, best_streak = ?, last_activity_date = ?, updated_at = ? WHERE user_id = ?",
            (current_streak, best_streak, today, now, user_id)
        )
    else:
        current_streak = 1
        best_streak = max(best_streak, current_streak)
        conn.execute(
            "UPDATE cognitive_streaks SET current_streak = ?, best_streak = ?, last_activity_date = ?, updated_at = ? WHERE user_id = ?",
            (current_streak, best_streak, today, now, user_id)
        )
    conn.commit()
    conn.close()

