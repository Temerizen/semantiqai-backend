            (built.get("title") or f"{topic} Mastery Track")[:200],
            (built.get("subject") or topic)[:120],
            level[:80],
            audience[:120],
            (built.get("description") or f"Adaptive course for {topic}.")[:3000],
            json.dumps(objectives[:20]),
            json.dumps([{"title": (x.get("title") or f"Lesson {i+1}")[:200], "lesson_type": x.get("lesson_type") or "core"} for i, x in enumerate(lessons[:20])]),
            topic[:500],
            visibility[:30],
            now,
            now
        )
    )
    course_id = cur.lastrowid

    for i, lesson in enumerate(lessons[:20], start=1):
        cur.execute(
            "INSERT INTO education_lessons (course_id, lesson_index, title, lesson_type, difficulty, estimated_minutes, content, exercises_json, key_terms_json, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
