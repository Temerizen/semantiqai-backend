def env_bool(name, default=False):
    val = os.getenv(name)
    if val is None:
        return default
    return str(val).strip().lower() in ("1", "true", "yes", "on")

def safe_user_id_from_auth_header():
    auth_header = request.headers.get("Authorization", "")
    if not auth_header.startswith("Bearer "):
        return None
    token = auth_header.split(" ", 2)[1].strip()
    try:
        payload = serializer.loads(token)
        if isinstance(payload, dict):
            return payload.get("id")
    except Exception:
        return None
    return None

def log_request_row(status_code=200, meta=None):
    try:
        if not env_bool("ENABLE_REQUEST_LOGS", True):
            return
        conn = db()
        conn.execute(
            "INSERT INTO request_logs (request_id, method, path, status_code, user_id, remote_addr, meta_json, created_at) "
            "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
            (
                getattr(g, "request_id", ""),
                request.method,
                request.path,
                int(status_code),
                safe_user_id_from_auth_header(),
                (request.headers.get("X-Forwarded-For") or request.remote_addr or "")[:255],
                json.dumps(meta or {}),
                utc_now()
            )
        )
        conn.commit()
        conn.close()
    except Exception:
        pass

def startup_validation():
    problems = []
    warnings = []

    if not os.getenv("JWT_SECRET"):
        problems.append("JWT_SECRET missing")
    elif "change_this" in (os.getenv("JWT_SECRET") or ""):
        warnings.append("JWT_SECRET still default-like")

    if not os.getenv("SECRET_KEY"):
        warnings.append("SECRET_KEY missing, falling back to JWT_SECRET")

    if not os.getenv("OPENAI_API_KEY"):
        warnings.append("OPENAI_API_KEY missing, AI responses may fallback")

    if not os.getenv("OPENAI_MODEL"):
        warnings.append("OPENAI_MODEL missing, default model will be used")

    return {
        "ok": len(problems) == 0,
        "problems": problems,
        "warnings": warnings,
        "env": os.getenv("APP_ENV", "production")
    }

