    built = _education_make_course(topic=topic, level=level, audience=audience)
    now = utc_now()
    lessons = built.get("lessons") or []
    objectives = built.get("objectives") or []

    conn = db()
    cur = conn.cursor()
    cur.execute(
        "INSERT INTO education_courses (user_id, title, subject, level, audience, description, objectives_json, syllabus_json, source_prompt, visibility, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
