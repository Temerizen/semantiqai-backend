        return jsonify({"error": "User not found"}), 404

    conn.execute("UPDATE users SET role = ? WHERE id = ?", (role, target_user_id))

    if _table_exists("moderation_actions"):
        conn.execute(
            "INSERT INTO moderation_actions (founder_user_id, action_type, target_type, target_id, payload_json, created_at) "
            "VALUES (?, ?, ?, ?, ?, ?)",
            (user["id"], "set_role", "user", target_user_id, json.dumps({"old_role": target["role"], "new_role": role}), utc_now())
        )

    conn.commit()
    updated = conn.execute("SELECT id, username, role, created_at FROM users WHERE id = ?", (target_user_id,)).fetchone()
    conn.close()
    return jsonify({"ok": True, "user": dict(updated)})

