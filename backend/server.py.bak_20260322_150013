def route_agents(user_input: str):
    text = (user_input or "").lower()
    chosen = ["aibrain_strategist"]

    if any(k in text for k in ["content", "copy", "launch post", "marketing", "homepage"]):
        chosen.append("content_generator")
    if any(k in text for k in ["founder", "operations", "ops", "priority", "schedule", "weekly"]):
        chosen.append("founder_os")
    if any(k in text for k in ["research", "analyze", "investigate", "study", "evidence"]):
        chosen.append("research_architect")
    if any(k in text for k in ["expand", "roadmap", "scale", "ecosystem", "future", "unfair"]):
        chosen.append("expansion_planner")

    # dedupe preserving order
    seen = set()
    ordered = []
    for c in chosen:
        if c not in seen:
            seen.add(c)
            ordered.append(c)
    return ordered

