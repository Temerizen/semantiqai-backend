    conn = db()
    profile = conn.execute("SELECT * FROM cognitive_profiles WHERE user_id = ?", (user["id"],)).fetchone()
    streak = conn.execute("SELECT * FROM cognitive_streaks WHERE user_id = ?", (user["id"],)).fetchone() if _table_exists_ccl("cognitive_streaks") else None
    due_cards = conn.execute(
        "SELECT COUNT(*) FROM recall_cards WHERE user_id = ? AND substr(next_review_at, 1, 10) <= ?",
        (user["id"], _today_iso())
    ).fetchone()[0] if _table_exists_ccl("recall_cards") else 0
    conn.close()

    goal = (profile["primary_goal"] if profile else "") or "clearer thinking"
    focus_window = int(profile["focus_window_minutes"] if profile else 45)

    protocol = [
        {"phase": "prime", "minutes": 5, "task": "Write today's cognitive target in one sentence."},
        {"phase": "focus", "minutes": focus_window, "task": f"Run one deep block aimed at {goal}."},
        {"phase": "recall", "minutes": 10, "task": f"Review due recall cards: {due_cards} due."},
        {"phase": "reasoning", "minutes": 15, "task": "Break one problem into assumptions, evidence, alternatives, and conclusion."},
        {"phase": "compression", "minutes": 10, "task": "Summarize one page, article, or concept from memory."}
    ]

    if founder_pro:
        protocol += [
            {"phase": "synthesis", "minutes": 20, "task": "Merge 2-3 sources into one operational insight memo."},
            {"phase": "decision", "minutes": 10, "task": "Write one decision journal entry using inversion and second-order effects."}
        ]

    return jsonify({
        "goal": goal,
        "focus_window_minutes": focus_window,
        "due_recall_cards": due_cards,
        "streak": dict(streak) if streak else None,
        "founder_pro": founder_pro,
        "protocol": protocol
    })

