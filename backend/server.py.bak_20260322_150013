def utc_now():
    return datetime.now(timezone.utc).isoformat()

def env_ok(value: str) -> bool:
    return bool(value and not value.startswith("CHANGE_THIS"))

def db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn

def startup_flags():
    public_url_ok = bool(PUBLIC_BASE_URL and PUBLIC_BASE_URL.startswith("http") and "your-domain-here.com" not in PUBLIC_BASE_URL)
    cors_ok = False
    if CORS_ORIGINS == "*":
        cors_ok = APP_STAGE != "production"
    elif isinstance(CORS_ORIGINS, list):
        cors_ok = len(CORS_ORIGINS) > 0 and all(o.startswith("http") for o in CORS_ORIGINS)

    return {
        "frontend_exists": (FRONTEND_DIR / "index.html").exists(),
        "database_exists": DB_PATH.exists(),
        "jwt_configured": env_ok(JWT_SECRET),
        "founder_password_configured": env_ok(FOUNDER_PASSWORD),
        "openai_key_configured": bool(OPENAI_API_KEY),
        "public_base_url_configured": public_url_ok,
        "cors_configured": cors_ok,
        "exports_exists": EXPORTS_DIR.exists(),
        "backups_exists": BACKUPS_DIR.exists(),
        "uploads_exists": UPLOADS_DIR.exists(),
    }

def checklist_items():
    flags = startup_flags()
    items = [
        {"item": "Frontend index exists", "ok": flags["frontend_exists"], "weight": 10},
        {"item": "Database initialized", "ok": flags["database_exists"], "weight": 10},
        {"item": "JWT secret configured", "ok": flags["jwt_configured"], "weight": 18},
        {"item": "Founder password configured", "ok": flags["founder_password_configured"], "weight": 12},
        {"item": "OpenAI API key configured", "ok": flags["openai_key_configured"], "weight": 10},
        {"item": "Public base URL configured", "ok": flags["public_base_url_configured"], "weight": 15},
        {"item": "CORS configured safely", "ok": flags["cors_configured"], "weight": 10},
        {"item": "Exports directory exists", "ok": flags["exports_exists"], "weight": 5},
        {"item": "Backups directory exists", "ok": flags["backups_exists"], "weight": 5},
        {"item": "Uploads directory exists", "ok": flags["uploads_exists"], "weight": 5},
    ]
    score = sum(item["weight"] for item in items if item["ok"])
    grade = "A" if score >= 90 else "B" if score >= 75 else "C" if score >= 60 else "D"
    return items, score, grade

