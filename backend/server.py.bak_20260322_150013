@app.post("/cognitive/recall-cards/<int:card_id>/review")
def recall_cards_review(card_id):
    user, err = require_user()
    if err:
        return err

    data = request.get_json(silent=True) or {}
    score = int(data.get("score") or 3)
    score = max(0, min(5, score))

    conn = db()
    row = conn.execute("SELECT * FROM recall_cards WHERE id = ? AND user_id = ?", (card_id, user["id"])).fetchone()
    if not row:
        conn.close()
        return jsonify({"error": "Card not found"}), 404

    reps = int(row["reps"] or 0)
    ease = float(row["ease_factor"] or 2.5)
    interval_days = int(row["interval_days"] or 1)

    if score < 3:
        reps = 0
        interval_days = 1
        ease = max(1.3, ease - 0.2)
    else:
        reps += 1
        if reps == 1:
            interval_days = 1
        elif reps == 2:
            interval_days = 3
        else:
            interval_days = max(1, max(math.floor(interval_days * ease), interval_days + 1))
        ease = min(3.2, max(1.3, ease + ((0.1 - (5 - score) * (0.08 + (5 - score) * 0.02)))))

    next_dt = (datetime.utcnow() + timedelta(days=interval_days)).strftime("%Y-%m-%dT%H:%M:%SZ")

    conn.execute(
        "UPDATE recall_cards SET ease_factor = ?, interval_days = ?, reps = ?, next_review_at = ?, last_score = ?, updated_at = ? WHERE id = ? AND user_id = ?",
        (ease, interval_days, reps, next_dt, score, utc_now(), card_id, user["id"])
    )
    conn.commit()
    updated = conn.execute(
        "SELECT id, deck_key, prompt, answer, tags_json, ease_factor, interval_days, reps, next_review_at, last_score, created_at, updated_at FROM recall_cards WHERE id = ? AND user_id = ?",
        (card_id, user["id"])
    ).fetchone()
    conn.close()

    _update_cognitive_streak(user["id"])
    return jsonify({"ok": True, "item": dict(updated)})

